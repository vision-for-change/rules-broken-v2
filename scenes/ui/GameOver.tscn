[gd_scene load_steps=2 format=3 uid="uid://go001"]

[sub_resource type="GDScript" id="s1"]
script/source = "extends Control
func _ready() -> void:
	ScreenFX.flash_screen(Color(1,0,0.1,0.6), 0.5)
	AudioManager.switch_music(\"stable\")
	$VBox/TitleLabel.add_theme_font_size_override(\"font_size\", 16)
	$VBox/TitleLabel.add_theme_color_override(\"font_color\", Color(1,0.2,0.2,1))
	$VBox/Sub.add_theme_font_size_override(\"font_size\", 8)
	$VBox/Sub.add_theme_color_override(\"font_color\", Color(0.7,0.5,0.5,1))
	$VBox/Hint.add_theme_font_size_override(\"font_size\", 7)
	$VBox/Hint.add_theme_color_override(\"font_color\", Color(0.4,0.4,0.5,1))
func _input(event):
	if event.is_action_pressed(\"ui_accept\"): get_tree().change_scene_to_file(\"res://scenes/levels/Level1.tscn\")
	if event.is_action_pressed(\"ui_cancel\"): get_tree().change_scene_to_file(\"res://scenes/ui/MainMenu.tscn\")
"

